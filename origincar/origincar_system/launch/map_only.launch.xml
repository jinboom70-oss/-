<launch>
  <arg name="map" default="/userdata/dev_ws/src/origincar/map/race_modify.yaml" description="Full path to map YAML file to load"/>
  <arg name="keepout_map" default="/userdata/dev_ws/src/origincar/map/race_keepout.yaml" description="Full path to keepout mask YAML file to load"/>
  <arg name="keepout_display_topic" default="/global_costmap/costmap" description="Display-only topic for RViz second Map panel"/>
  <arg name="use_sim_time" default="false" description="Use simulation clock if true"/>
  <arg name="params_file" default="/userdata/dev_ws/src/origincar/origincar_system/config/controller_params_keepout.yaml" description="Parameter file containing AMCL settings"/>

  <node pkg="nav2_map_server" exec="map_server" name="map_server" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="yaml_filename" value="$(var map)"/>
  </node>

  <node pkg="nav2_amcl" exec="amcl" name="amcl" output="screen">
    <param from="$(var params_file)"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <node pkg="nav2_map_server" exec="costmap_filter_info_server" name="costmap_filter_info_server" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="filter_info_topic" value="/filter_mask_info"/>
    <param name="type" value="0"/>
    <param name="mask_topic" value="/filter_mask"/>
    <param name="base" value="0.0"/>
    <param name="multiplier" value="1.0"/>
  </node>

  <node pkg="nav2_map_server" exec="map_server" name="filter_mask_server" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="yaml_filename" value="$(var keepout_map)"/>
    <param name="topic_name" value="/filter_mask"/>
    <param name="frame_id" value="map"/>
  </node>

  <node pkg="nav2_map_server" exec="map_server" name="keepout_display_server" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="yaml_filename" value="$(var keepout_map)"/>
    <param name="topic_name" value="$(var keepout_display_topic)"/>
    <param name="frame_id" value="map"/>
  </node>

  <node pkg="nav2_lifecycle_manager" exec="lifecycle_manager" name="lifecycle_manager_localization_only" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="autostart" value="true"/>
    <param name="node_names" value="['map_server', 'amcl']"/>
    <param name="bond_timeout" value="10.0"/>
  </node>

  <node pkg="nav2_lifecycle_manager" exec="lifecycle_manager" name="lifecycle_manager_keepout_only" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="autostart" value="true"/>
    <param name="node_names" value="['costmap_filter_info_server', 'filter_mask_server', 'keepout_display_server']"/>
    <param name="bond_timeout" value="10.0"/>
  </node>
</launch>
